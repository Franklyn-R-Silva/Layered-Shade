{
  "name": "layered-shade",
  "version": "2.0.0",
  "description": "Layered Shade - Box Shadow Generator for CSS & Flutter (Svelte 5 + Vite + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "box-shadow",
    "css",
    "flutter",
    "dart",
    "shadow-generator"
  ],
  "author": "Franklyn R. Silva",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.8.9",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.4"
  }
}
